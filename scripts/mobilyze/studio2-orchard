#!/bin/bash
set -euo pipefail

TART_VERSION="2.32.1"
TART_RELEASE="2.32.1-r1"
TART_SHA256="8554ab4f7fc12afe52f9b7e3093a935673cbac737a83973d2db7a0683c814529"
ORCHARD_VERSION="0.55.0"
ORCHARD_SHA256="35a6ca9f1770a6da9ccc508cee46df21f962d4c5fb437161e4fe8daa34bb14fe"
VALIDATION_IMAGE="ghcr.io/cirruslabs/ubuntu@sha256:6c88f37c40254499ecae810fd450fa7f92e0f1f68c48bc3339ee18522b9c8655"
SERVICE_USER="_opensweorchard"
SERVICE_GROUP="_opensweorchard"
SERVICE_UID="450"
SERVICE_GID="450"
SOFTWARE_ROOT="/opt/mobilyze/open-swe-orchard"
STATE_ROOT="/var/db/mobilyze-open-swe-orchard"
CONFIG_ROOT="/Library/Application Support/Mobilyze/OpenSWEOrchard"
LOG_ROOT="/var/log/mobilyze-open-swe-orchard"
BACKUP_ROOT="/var/backups/mobilyze-open-swe-orchard"
TAILSCALE_BIN="/usr/local/bin/tailscale"
DHCP_PREFS="/Library/Preferences/SystemConfiguration/com.apple.InternetSharing.default.plist"
CONTROLLER_ADDRESS="100.107.128.12"
CONTROLLER_URL="https://${CONTROLLER_ADDRESS}:6120"
CONTROLLER_LABEL="com.mobilyze.open-swe.orchard.controller"
WORKER_LABEL="com.mobilyze.open-swe.orchard.worker"
WORKER_NAME="studio2-open-swe"
TART_BIN="${SOFTWARE_ROOT}/current/tart.app/Contents/MacOS/tart"
ORCHARD_BIN="${SOFTWARE_ROOT}/current/orchard"
OPERATOR_HOME="${STATE_ROOT}/operator"
SECRETS_ROOT="${CONFIG_ROOT}/secrets"

usage() {
  echo "usage: $0 validate MANIFEST | install | status | start | stop | restart | unauthenticated-probe | vm-create NAME | vm-list | vm-exec NAME | vm-stop NAME | vm-delete NAME | verify NAME | manifest | backup | rollback | uninstall [--confirm]" >&2
  exit 64
}

require_root() {
  [[ "$(id -u)" == "0" ]] || { echo "root is required" >&2; exit 77; }
}

validate_name() {
  [[ "${1:-}" =~ ^[a-z][a-z0-9-]{2,40}$ ]] || { echo "invalid VM name" >&2; exit 64; }
}

as_service() {
  sudo -u "$SERVICE_USER" env HOME="$STATE_ROOT" ORCHARD_HOME="$OPERATOR_HOME" "$@"
}

orchard() {
  as_service "$ORCHARD_BIN" "$@"
}

validate_manifest() {
  [[ $# == 1 ]] || usage
  python3 - "$1" <<'PY'
import json
import pathlib
import sys

manifest = json.loads(pathlib.Path(sys.argv[1]).read_text())
assert manifest["schema"] == "mobilyze.open-swe.studio2-orchard-baseline.v1"
assert manifest["controller"]["url"].startswith("https://100.107.128.12:")
assert manifest["controller"]["credential"] == "REDACTED"
assert manifest["worker"]["bootstrap_credential"] == "REDACTED"
assert manifest["limits"]["max_concurrent_vms"] == 2
assert manifest["secrets_present"] is False
for path in manifest["paths"].values():
    assert path.startswith(("/opt/", "/var/", "/Library/"))
    assert "/Users/" not in path
print("baseline valid")
PY
}

install_identity() {
  if ! dscl . -read "/Groups/${SERVICE_GROUP}" >/dev/null 2>&1; then
    ! dscl . -list /Groups PrimaryGroupID | awk '{print $2}' | grep -qx "$SERVICE_GID"
    dscl . -create "/Groups/${SERVICE_GROUP}"
    dscl . -create "/Groups/${SERVICE_GROUP}" PrimaryGroupID "$SERVICE_GID"
  fi
  if ! dscl . -read "/Users/${SERVICE_USER}" >/dev/null 2>&1; then
    ! dscl . -list /Users UniqueID | awk '{print $2}' | grep -qx "$SERVICE_UID"
    dscl . -create "/Users/${SERVICE_USER}"
    dscl . -create "/Users/${SERVICE_USER}" UniqueID "$SERVICE_UID"
    dscl . -create "/Users/${SERVICE_USER}" PrimaryGroupID "$SERVICE_GID"
    dscl . -create "/Users/${SERVICE_USER}" NFSHomeDirectory "$STATE_ROOT"
    dscl . -create "/Users/${SERVICE_USER}" UserShell /usr/bin/false
    dscl . -create "/Users/${SERVICE_USER}" IsHidden 1
    dscl . -create "/Users/${SERVICE_USER}" AuthenticationAuthority ";DisabledUser;"
  fi
}

install_artifacts() {
  local staging tart_archive orchard_download
  staging="$(mktemp -d /tmp/oswe-orchard-install.XXXXXX)"
  tart_archive="${staging}/tart.tar.gz"
  orchard_download="${staging}/orchard"
  curl -fsSL "https://github.com/openai/tart/releases/download/${TART_VERSION}/tart.tar.gz" -o "$tart_archive"
  echo "${TART_SHA256}  ${tart_archive}" | shasum -a 256 -c -
  mkdir "${staging}/tart"
  tar -xzf "$tart_archive" -C "${staging}/tart"
  spctl --assess --type execute "${staging}/tart/tart.app"
  "${staging}/tart/tart.app/Contents/MacOS/tart" --version | grep -qx "$TART_VERSION"
  curl -fsSL "https://github.com/openai/orchard/releases/download/${ORCHARD_VERSION}/orchard-darwin-arm64" -o "$orchard_download"
  echo "${ORCHARD_SHA256}  ${orchard_download}" | shasum -a 256 -c -
  chmod 0755 "$orchard_download"
  "$orchard_download" --version | grep -q "orchard version ${ORCHARD_VERSION}-"
  mkdir -p /opt/mobilyze "${SOFTWARE_ROOT}/releases/tart/${TART_RELEASE}" "${SOFTWARE_ROOT}/releases/orchard/${ORCHARD_VERSION}"
  chmod 0755 /opt/mobilyze
  if [[ ! -x "${SOFTWARE_ROOT}/releases/tart/${TART_RELEASE}/tart.app/Contents/MacOS/tart" ]]; then
    tar -xzf "$tart_archive" -C "${SOFTWARE_ROOT}/releases/tart/${TART_RELEASE}"
  fi
  if [[ ! -x "${SOFTWARE_ROOT}/releases/orchard/${ORCHARD_VERSION}/orchard" ]]; then
    install -o root -g wheel -m 0755 "$orchard_download" "${SOFTWARE_ROOT}/releases/orchard/${ORCHARD_VERSION}/orchard"
  fi
  "${SOFTWARE_ROOT}/releases/tart/${TART_RELEASE}/tart.app/Contents/MacOS/tart" --version | grep -qx "$TART_VERSION"
  "${SOFTWARE_ROOT}/releases/orchard/${ORCHARD_VERSION}/orchard" --version | grep -q "orchard version ${ORCHARD_VERSION}-"
  ln -sfn "${SOFTWARE_ROOT}/releases/tart/${TART_RELEASE}" "${SOFTWARE_ROOT}/current-tart"
  ln -sfn "${SOFTWARE_ROOT}/releases/orchard/${ORCHARD_VERSION}" "${SOFTWARE_ROOT}/current-orchard"
  mkdir -p "${SOFTWARE_ROOT}/current"
  ln -sfn "${SOFTWARE_ROOT}/current-tart/tart.app" "${SOFTWARE_ROOT}/current/tart.app"
  ln -sfn "${SOFTWARE_ROOT}/current-tart/tart.app/Contents/MacOS/tart" "${SOFTWARE_ROOT}/current/tart"
  ln -sfn "${SOFTWARE_ROOT}/current-orchard/orchard" "${SOFTWARE_ROOT}/current/orchard"
  chmod 0755 "$SOFTWARE_ROOT" "${SOFTWARE_ROOT}/releases" "${SOFTWARE_ROOT}/releases/tart" "${SOFTWARE_ROOT}/releases/orchard" "${SOFTWARE_ROOT}/current"
}

install_layout() {
  mkdir -p "$STATE_ROOT" "$OPERATOR_HOME" "${STATE_ROOT}/controller" "$CONFIG_ROOT" "$SECRETS_ROOT" "$LOG_ROOT" "$BACKUP_ROOT"
  chown -R "${SERVICE_USER}:${SERVICE_GROUP}" "$STATE_ROOT" "$LOG_ROOT"
  chmod 0700 "$STATE_ROOT" "$OPERATOR_HOME" "$SECRETS_ROOT" "$LOG_ROOT" "$BACKUP_ROOT"
  chown "root:${SERVICE_GROUP}" "$CONFIG_ROOT"
  chmod 0750 "$CONFIG_ROOT"
  for secret in bootstrap-admin operator-token worker-token; do
    if [[ ! -s "${SECRETS_ROOT}/${secret}" ]]; then
      (umask 077; openssl rand -hex 32 >"${SECRETS_ROOT}/${secret}")
    fi
  done
  chown -R "${SERVICE_USER}:${SERVICE_GROUP}" "$SECRETS_ROOT"
  chmod 0400 "${SECRETS_ROOT}"/*
  defaults write "$DHCP_PREFS" bootpd -dict DHCPLeaseTimeSecs -int 600
}

install_launchd() {
  mkdir -p /usr/local/sbin /usr/local/libexec
  install -o root -g wheel -m 0755 "$0" /usr/local/sbin/studio2-orchard
  cat >/usr/local/libexec/open-swe-orchard-controller <<EOF
#!/bin/bash
set -euo pipefail
"${TAILSCALE_BIN}" up
for _ in {1..60}; do
  if ifconfig | grep -q 'inet ${CONTROLLER_ADDRESS} '; then break; fi
  sleep 2
done
ifconfig | grep -q 'inet ${CONTROLLER_ADDRESS} '
export HOME="${STATE_ROOT}"
export ORCHARD_HOME="${STATE_ROOT}"
export ORCHARD_BOOTSTRAP_ADMIN_TOKEN="\$(cat '${SECRETS_ROOT}/bootstrap-admin')"
exec '${ORCHARD_BIN}' controller run --data-dir '${STATE_ROOT}/controller' --listen '${CONTROLLER_ADDRESS}:6120'
EOF
  cat >/usr/local/libexec/open-swe-orchard-worker <<EOF
#!/bin/bash
set -euo pipefail
export HOME='${STATE_ROOT}'
export ORCHARD_HOME='${STATE_ROOT}/worker'
export PATH='${SOFTWARE_ROOT}/current:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin'
exec '${ORCHARD_BIN}' worker run --bootstrap-token-stdin --no-pki --user '${SERVICE_USER}' --name '${WORKER_NAME}' --labels oswe.pool=apple --resources oswe.vm-slots=2 --default-cpu 4 --default-memory 8192 '${CONTROLLER_URL}' <'${SECRETS_ROOT}/worker-bootstrap'
EOF
  chmod 0755 /usr/local/libexec/open-swe-orchard-controller /usr/local/libexec/open-swe-orchard-worker
  cat >/Library/LaunchDaemons/${CONTROLLER_LABEL}.plist <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict><key>Label</key><string>${CONTROLLER_LABEL}</string><key>ProgramArguments</key><array><string>/usr/local/libexec/open-swe-orchard-controller</string></array><key>UserName</key><string>${SERVICE_USER}</string><key>GroupName</key><string>${SERVICE_GROUP}</string><key>RunAtLoad</key><true/><key>KeepAlive</key><true/><key>StandardOutPath</key><string>${LOG_ROOT}/controller.log</string><key>StandardErrorPath</key><string>${LOG_ROOT}/controller.log</string></dict></plist>
EOF
  cat >/Library/LaunchDaemons/${WORKER_LABEL}.plist <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict><key>Label</key><string>${WORKER_LABEL}</string><key>ProgramArguments</key><array><string>/usr/local/libexec/open-swe-orchard-worker</string></array><key>RunAtLoad</key><true/><key>KeepAlive</key><true/><key>StandardOutPath</key><string>${LOG_ROOT}/worker-launchd.log</string><key>StandardErrorPath</key><string>${LOG_ROOT}/worker-launchd.log</string></dict></plist>
EOF
  chown root:wheel /Library/LaunchDaemons/${CONTROLLER_LABEL}.plist /Library/LaunchDaemons/${WORKER_LABEL}.plist
  chmod 0600 /Library/LaunchDaemons/${CONTROLLER_LABEL}.plist /Library/LaunchDaemons/${WORKER_LABEL}.plist
  plutil -lint /Library/LaunchDaemons/${CONTROLLER_LABEL}.plist /Library/LaunchDaemons/${WORKER_LABEL}.plist
}

bootstrap_accounts() {
  local bootstrap operator_token worker_token
  bootstrap="$(cat "${SECRETS_ROOT}/bootstrap-admin")"
  operator_token="$(cat "${SECRETS_ROOT}/operator-token")"
  worker_token="$(cat "${SECRETS_ROOT}/worker-token")"
  launchctl bootout system "/Library/LaunchDaemons/${CONTROLLER_LABEL}.plist" >/dev/null 2>&1 || true
  launchctl bootstrap system "/Library/LaunchDaemons/${CONTROLLER_LABEL}.plist"
  for _ in {1..30}; do nc -z "$CONTROLLER_ADDRESS" 6120 && break; sleep 1; done
  nc -z "$CONTROLLER_ADDRESS" 6120
  printf 'yes\n' | as_service "$ORCHARD_BIN" context create "$CONTROLLER_URL" --name bootstrap --no-pki --force --service-account-name bootstrap-admin --service-account-token "$bootstrap"
  ORCHARD_HOME="$OPERATOR_HOME" as_service "$ORCHARD_BIN" context default bootstrap
  orchard get service-account oswe-operator >/dev/null 2>&1 || orchard create service-account oswe-operator --token "$operator_token" --roles compute:read --roles compute:write --roles compute:connect --roles admin:read
  orchard get service-account oswe-worker >/dev/null 2>&1 || orchard create service-account oswe-worker --token "$worker_token" --roles compute:read --roles compute:write
  printf 'yes\n' | as_service "$ORCHARD_BIN" context create "$CONTROLLER_URL" --name operator --no-pki --force --service-account-name oswe-operator --service-account-token "$operator_token"
  orchard context default operator
  orchard get bootstrap-token oswe-worker >"${SECRETS_ROOT}/worker-bootstrap"
  chown "${SERVICE_USER}:${SERVICE_GROUP}" "${SECRETS_ROOT}/worker-bootstrap"
  chmod 0400 "${SECRETS_ROOT}/worker-bootstrap"
  launchctl bootout system "/Library/LaunchDaemons/${WORKER_LABEL}.plist" >/dev/null 2>&1 || true
  launchctl bootstrap system "/Library/LaunchDaemons/${WORKER_LABEL}.plist"
}

install_all() {
  require_root
  [[ "$(hostname -s)" == "studio2" ]] || { echo "refusing non-studio2 host" >&2; exit 78; }
  [[ "$("$TAILSCALE_BIN" ip -4)" == "$CONTROLLER_ADDRESS" ]] || { echo "unexpected Tailscale address" >&2; exit 78; }
  install_identity
  install_layout
  install_artifacts
  install_launchd
  bootstrap_accounts
  status_all
}

status_all() {
  require_root
  "$TART_BIN" --version
  "$ORCHARD_BIN" --version
  launchctl print "system/${CONTROLLER_LABEL}" | grep -E 'state =|pid ='
  launchctl print "system/${WORKER_LABEL}" | grep -E 'state =|pid ='
  orchard list workers
  df -h "$STATE_ROOT" | awk 'NR == 1 || NR == 2'
}

start_all() {
  require_root
  launchctl bootstrap system "/Library/LaunchDaemons/${CONTROLLER_LABEL}.plist" 2>/dev/null || launchctl kickstart -k "system/${CONTROLLER_LABEL}"
  launchctl bootstrap system "/Library/LaunchDaemons/${WORKER_LABEL}.plist" 2>/dev/null || launchctl kickstart -k "system/${WORKER_LABEL}"
}

stop_all() {
  require_root
  launchctl bootout system "/Library/LaunchDaemons/${WORKER_LABEL}.plist" 2>/dev/null || true
  launchctl bootout system "/Library/LaunchDaemons/${CONTROLLER_LABEL}.plist" 2>/dev/null || true
}

vm_create() {
  require_root; validate_name "$1"
  orchard create vm "$1" --image "$VALIDATION_IMAGE" --os linux --runtime tart --cpu 4 --memory 8192 --disk-size 40 --resources oswe.vm-slots=1 --labels oswe.pool=apple --restart-policy Never
}

vm_exec() {
  require_root; validate_name "$1"
  orchard ssh vm "$1" --username admin --password admin --wait 900 "printf 'oswe14-exec-ok\\n'; uname -a"
}

vm_stop() {
  require_root; validate_name "$1"
  local tart_name
  tart_name="$(as_service "$TART_BIN" list --source local --format json | python3 -c 'import json,sys; prefix="orchard-"+sys.argv[1]+"-"; print(next((vm["Name"] for vm in json.load(sys.stdin) if vm["Name"].startswith(prefix) and vm["Running"]), ""))' "$1")"
  [[ -n "$tart_name" ]] || { echo "running Tart VM not found for $1" >&2; exit 1; }
  as_service "$TART_BIN" stop "$tart_name"
  echo "stopped Tart VM: $tart_name"
}

verify_vm() {
  require_root; validate_name "$1"
  vm_create "$1"
  orchard list vms
  for _ in {1..180}; do orchard get vm "$1" | awk '$1 == "Status" && $2 == "running" {found=1} END {exit !found}' && break; sleep 5; done
  orchard get vm "$1" | awk '$1 == "Status" && $2 == "running" {found=1} END {exit !found}'
  vm_exec "$1"
  vm_stop "$1"
  orchard delete vm "$1"
  ! orchard get vm "$1" >/dev/null 2>&1
  echo "lifecycle complete: $1"
}

probe_unauthenticated() {
  require_root
  local code
  code="$(curl -ksS -o /dev/null -w '%{http_code}' "${CONTROLLER_URL}/v1/vms")"
  [[ "$code" == "401" ]] || { echo "expected 401, got ${code}" >&2; exit 1; }
  echo "unauthenticated request denied: HTTP ${code}"
}

write_manifest() {
  require_root
  local free_gib controller_state worker_state
  free_gib="$(( $(df -Pk "$STATE_ROOT" | awk 'NR == 2 {print $4}') / 1024 / 1024 ))"
  controller_state="$(launchctl print "system/${CONTROLLER_LABEL}" | awk '/state =/ {print $3; exit}')"
  worker_state="$(launchctl print "system/${WORKER_LABEL}" | awk '/state =/ {print $3; exit}')"
  printf '{"schema":"mobilyze.open-swe.studio2-orchard-live.v1","host":"studio2","controller_url":"%s","authentication":"required","credential":"REDACTED","service_identity":"%s","tart_version":"%s","orchard_version":"%s","controller_state":"%s","worker_state":"%s","max_concurrent_vms":2,"observed_free_disk_gib":%s,"secrets_present":false}\n' "$CONTROLLER_URL" "$SERVICE_USER" "$TART_VERSION" "$ORCHARD_VERSION" "$controller_state" "$worker_state" "$free_gib"
}

backup_state() {
  require_root
  stop_all
  local archive="${BACKUP_ROOT}/controller-$(date -u +%Y%m%dT%H%M%SZ).tar.gz"
  tar -czf "$archive" -C "$STATE_ROOT" controller
  chmod 0600 "$archive"
  start_all
  echo "$archive"
}

rollback_pins() {
  require_root
  ln -sfn "${SOFTWARE_ROOT}/releases/tart/${TART_RELEASE}" "${SOFTWARE_ROOT}/current-tart"
  ln -sfn "${SOFTWARE_ROOT}/releases/orchard/${ORCHARD_VERSION}" "${SOFTWARE_ROOT}/current-orchard"
  restart_all
  status_all
}

restart_all() { stop_all; start_all; }

uninstall_all() {
  require_root
  [[ "${1:-}" == "--confirm" ]] || {
    printf 'would remove %s, %s, %s, %s and identity %s\n' "$SOFTWARE_ROOT" "$STATE_ROOT" "$CONFIG_ROOT" "$LOG_ROOT" "$SERVICE_USER"
    return
  }
  stop_all
  rm -f "/Library/LaunchDaemons/${CONTROLLER_LABEL}.plist" "/Library/LaunchDaemons/${WORKER_LABEL}.plist" /usr/local/libexec/open-swe-orchard-controller /usr/local/libexec/open-swe-orchard-worker /usr/local/sbin/studio2-orchard
  rm -rf "$SOFTWARE_ROOT" "$STATE_ROOT" "$CONFIG_ROOT" "$LOG_ROOT" "$BACKUP_ROOT"
  dscl . -delete "/Users/${SERVICE_USER}"; dscl . -delete "/Groups/${SERVICE_GROUP}"
}

command="${1:-}"; shift || true
case "$command" in
  validate) validate_manifest "$@" ;;
  install) install_all ;;
  status) status_all ;;
  start) require_root; start_all ;;
  stop) require_root; stop_all ;;
  restart) require_root; restart_all ;;
  unauthenticated-probe) probe_unauthenticated ;;
  vm-create) [[ $# == 1 ]] || usage; vm_create "$1" ;;
  vm-list) require_root; orchard list vms ;;
  vm-exec) [[ $# == 1 ]] || usage; vm_exec "$1" ;;
  vm-stop) [[ $# == 1 ]] || usage; vm_stop "$1" ;;
  vm-delete) [[ $# == 1 ]] || usage; require_root; validate_name "$1"; orchard delete vm "$1" ;;
  verify) [[ $# == 1 ]] || usage; verify_vm "$1" ;;
  manifest) write_manifest ;;
  backup) backup_state ;;
  rollback) rollback_pins ;;
  uninstall) uninstall_all "$@" ;;
  *) usage ;;
esac
