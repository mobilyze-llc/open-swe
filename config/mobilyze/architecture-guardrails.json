{
  "$schema": "./architecture-guardrails.schema.json",
  "schema": "mobilyze.open-swe.architecture-guardrails.v1",
  "custom_path_globs": [
    "agent/mobilyze/**",
    "tests/mobilyze/**",
    "docs/mobilyze/**",
    "config/mobilyze/**",
    "scripts/mobilyze/**",
    ".github/workflows/mobilyze-*.yml"
  ],
  "source_extensions": [
    ".py",
    ".js",
    ".mjs",
    ".cjs",
    ".ts",
    ".tsx",
    ".swift",
    ".sh"
  ],
  "exempt_path_globs": [
    "tests/**",
    "docs/**",
    "**/__generated__/**",
    "**/generated/**",
    "**/*.generated.*"
  ],
  "new_file_line_cap": 350,
  "no_growth_line_threshold": 600,
  "integration_seams": [
    {
      "path": "AGENTS.md",
      "purpose": "Point agents at the Mobilyze fork policy without replacing upstream guidance.",
      "max_added_lines_per_pr": 16
    },
    {
      "path": "agent/utils/model.py",
      "purpose": "Select a deployment-configured base URL for the existing direct OpenAI Responses path.",
      "max_added_lines_per_pr": 3
    },
    {
      "path": "docs/CUSTOMIZATION.md",
      "purpose": "Document deployment-scoped OpenAI endpoint and credential configuration.",
      "max_added_lines_per_pr": 10
    },
    {
      "path": "docs/INSTALLATION.md",
      "purpose": "Expose the optional OpenAI endpoint variable in the installation environment template.",
      "max_added_lines_per_pr": 1
    },
    {
      "path": "tests/sandbox/test_gateway.py",
      "purpose": "Pin direct endpoint selection and LangSmith Gateway precedence for OpenAI models.",
      "max_added_lines_per_pr": 12
    }
  ],
  "waivers": []
}
