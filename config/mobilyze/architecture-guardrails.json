{
  "$schema": "./architecture-guardrails.schema.json",
  "schema": "mobilyze.open-swe.architecture-guardrails.v1",
  "custom_path_globs": [
    "agent/mobilyze/**",
    "tests/mobilyze/**",
    "docs/mobilyze/**",
    "config/mobilyze/**",
    "scripts/mobilyze/**",
    ".github/workflows/mobilyze-*.yml"
  ],
  "source_extensions": [
    ".py",
    ".js",
    ".mjs",
    ".cjs",
    ".ts",
    ".tsx",
    ".swift",
    ".sh"
  ],
  "exempt_path_globs": [
    "tests/**",
    "docs/**",
    "**/__generated__/**",
    "**/generated/**",
    "**/*.generated.*"
  ],
  "new_file_line_cap": 350,
  "no_growth_line_threshold": 600,
  "integration_seams": [
    {
      "path": "AGENTS.md",
      "purpose": "Point agents at the Mobilyze fork policy without replacing upstream guidance.",
      "max_added_lines_per_pr": 16
    },
    {
      "path": "agent/utils/linear_team_repo_map.py",
      "purpose": "Route the fork's Open SWE Linear team to the selected Mobilyze pilot repository.",
      "max_added_lines_per_pr": 1
    },
    {
      "path": "tests/github/test_repo_extraction.py",
      "purpose": "Keep the upstream Linear routing contract aligned with the declared Mobilyze team mapping seam.",
      "max_added_lines_per_pr": 2
    }
  ],
  "waivers": []
}
